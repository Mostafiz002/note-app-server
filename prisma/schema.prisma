datasource db {
  provider = "sqlite"
}

generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  moduleFormat  = "cjs"
}

model User {
  id        Int     @default(autoincrement()) @id
  name      String?
  email     String  @unique
  password  String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  Note      Note[]
}

model Note {
  id    Int     @default(autoincrement()) @id
  title  String
  body String  
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
  userId Int
}